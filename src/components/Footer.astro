---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
	<div class="container">
		<div class="footer-content">
			<p class="copyright">© {currentYear} Tamerlan Baimurat. All rights reserved.</p>
			<p class="built-with">
				Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
				<img src="/public/favicon.svg" alt="Astro Logo" class="astro-logo" />
			</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		padding: 2rem;
		background: #f8f9fa;
		border-top: 1px solid rgba(var(--accent), 0.1);
	}

	.container {
		max-width: 1000px;
		margin: 0 auto;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.copyright {
		color: #666;
		font-size: 0.9rem;
	}

	.built-with {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #666;
		font-size: 0.9rem;
	}

	.built-with a {
		color: rgb(var(--accent));
		text-decoration: none;
		font-weight: 500;
		transition: color 0.2s;
	}

	.built-with a:hover {
		color: rgb(var(--accent-dark));
	}

	.astro-logo {
		width: 20px;
		height: 20px;
		vertical-align: middle;
	}

	@media (max-width: 768px) {
		.footer-content {
			flex-direction: column;
			text-align: center;
			gap: 0.5rem;
		}
	}
</style> 